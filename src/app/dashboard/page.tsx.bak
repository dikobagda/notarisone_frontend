  { id: "4", title: "Akta Wasiat", client: "Robert Chen", date: "11 Apr 2024", status: "Final" },
  { id: "5", title: "Surat Kuasa Menjual", client: "Dewi Lestari", date: "10 Apr 2024", status: "Draft" },
];

export default function DashboardPage() {
  return (
    <div className="flex flex-col gap-8">
      {/* Welcome Section */}
      <section className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
          <h2 className="text-3xl font-bold tracking-tight text-foreground">Selamat Datang, Notaris Ahmad</h2>
          <p className="text-muted-foreground mt-1 text-lg">Inilah ringkasan aktivitas kantor Anda hari ini.</p>
        </div>
        <div className="flex gap-3">
          <Button variant="outline" className="gap-2">
            Lihat Laporan
          </Button>
          <Button className="gap-2">
            <Plus className="h-4 w-4" />
            Buat Akta Baru
          </Button>
        </div>
      </section>

      {/* Stats Cards */}
      <section className="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {stats.map((stat) => (
          <Card key={stat.title} className="border-none shadow-sm bg-card hover:shadow-md transition-shadow">
            <CardHeader className="flex flex-row items-center justify-between pb-2">
              <CardTitle className="text-sm font-semibold text-muted-foreground">{stat.title}</CardTitle>
              <stat.icon className="h-4 w-4 text-accent" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">{stat.value}</div>
              <p className="text-xs text-muted-foreground mt-1">
                <span className={stat.trend === "up" ? "text-emerald-500 font-medium" : "text-muted-foreground"}>
                  {stat.description}
                </span>
              </p>
            </CardContent>
          </Card>
        ))}
      </section>

      <div className="grid gap-8 md:grid-cols-2 lg:grid-cols-7">
        {/* Recent Deeds Table */}
        <Card className="lg:col-span-4 border-none shadow-sm">
          <CardHeader>
            <CardTitle>Akta Terbaru</CardTitle>
            <CardDescription>Daftar akta yang sedang diproses atau baru saja selesai.</CardDescription>
          </CardHeader>
          <CardContent>
            <Table>
              <TableHeader>
                <TableRow className="hover:bg-transparent">
                  <TableHead>Nama Akta</TableHead>
                  <TableHead>Klien</TableHead>
                  <TableHead>Tanggal</TableHead>
                  <TableHead>Status</TableHead>
                  <TableHead className="text-right"></TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {recentDeeds.map((deed) => (
                  <TableRow key={deed.id} className="group transition-colors">
                    <TableCell className="font-medium">{deed.title}</TableCell>
                    <TableCell>{deed.client}</TableCell>
                    <TableCell>{deed.date}</TableCell>
                    <TableCell>
                      <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                        deed.status === "Final" ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400" :
                        deed.status === "Draft" ? "bg-slate-100 text-slate-800 dark:bg-slate-800/50 dark:text-slate-400" :
                        "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400"
                      }`}>
                        {deed.status}
                      </span>
                    </TableCell>
                    <TableCell className="text-right">
                      <Button variant="ghost" size="icon" className="h-8 w-8 opacity-0 group-hover:opacity-100 transition-opacity">
                        <MoreHorizontal className="h-4 w-4" />
                      </Button>
