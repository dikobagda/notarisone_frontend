"use client";

import { usePathname } from "next/navigation";
import { cn } from "@/lib/utils";
import {
  FileText,
  LayoutDashboard,
  CreditCard,
  Users,
  BookOpen,
  Calendar,
  Settings,
  ChevronRight,
  LogOut,
  User as UserIcon,
  ShieldCheck,
} from "lucide-react";

import {
  Sidebar,
  SidebarContent,
  SidebarFooter,
  SidebarHeader,
  SidebarGroup,
  SidebarGroupContent,
  SidebarGroupLabel,
  SidebarMenu,
  SidebarMenuButton,
  SidebarMenuItem,
} from "@/components/ui/sidebar";

const mainItems = [
  {
    title: "Beranda",
    url: "/dashboard",
    icon: LayoutDashboard,
  },
  {
    title: "Manajemen Akta",
    url: "/dashboard/deeds",
    icon: FileText,
  },
  {
    title: "Keuangan",
    url: "/dashboard/billing",
    icon: CreditCard,
  },
];

const supportItems = [
  {
    title: "Manajemen Klien",
    url: "/dashboard/klien",
    icon: Users,
  },
  {
    title: "Protokol Digital",
    url: "/dashboard/protokol",
    icon: BookOpen,
  },
  {
    title: "Manajemen Tim",
    url: "/dashboard/tim",
    icon: ShieldCheck,
  },
  {
    title: "Penjadwalan",
    url: "/dashboard/jadwal",
    icon: Calendar,
  },
];

export function AppSidebar() {
  const pathname = usePathname();

  const renderMenuItems = (menuItems: typeof mainItems) => (
    <SidebarMenu>
      {menuItems.map((item) => {
        const isActive = pathname === item.url;
        return (
          <SidebarMenuItem key={item.title}>
            <SidebarMenuButton 
              tooltip={item.title} 
              render={<a href={item.url} />}
              isActive={isActive}
              className={cn(
                "group/item relative px-5 py-6 transition-all duration-300 rounded-lg my-1",
                isActive 
                  ? "bg-muted/50 text-black shadow-sm" 
                  : "hover:bg-muted/30 text-muted-foreground font-medium"
              )}
            >
              <item.icon className={cn(
                "h-5 w-5 transition-all duration-300",
                isActive ? "scale-110 text-black" : "text-muted-foreground group-hover/item:text-black group-hover/item:scale-110"
              )} />
              <span className={cn(
                "tracking-tight transition-colors duration-300",
                isActive ? "font-bold text-black" : "text-muted-foreground group-hover/item:text-black"
              )}>{item.title}</span>
            </SidebarMenuButton>
          </SidebarMenuItem>
        );
      })}
    </SidebarMenu>
  );

  return (
    <Sidebar collapsible="icon" className="border-r border-border">
      <SidebarHeader className="p-4">
        <div className="flex items-center gap-3 px-1">
          <div className="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-primary-foreground font-bold text-xl shadow-lg shadow-primary/20">
            N
          </div>
          <div className="flex flex-col gap-0.5 leading-none text-sidebar-foreground">
            <span className="font-semibold text-lg tracking-tight">NotarisOne</span>
            <span className="text-[10px] text-sidebar-foreground/50 font-bold tracking-widest uppercase">Premium SaaS</span>
          </div>
        </div>
      </SidebarHeader>
        <SidebarContent className="overflow-x-hidden">
          <SidebarGroup>
            <SidebarGroupLabel className="px-5 text-[10px] font-black uppercase tracking-[0.2em] text-sidebar-foreground/30 mt-6 mb-2">
              Operasional Utama
            </SidebarGroupLabel>
            <SidebarGroupContent className="px-2">
              {renderMenuItems(mainItems)}
            </SidebarGroupContent>
          </SidebarGroup>

          <SidebarGroup className="mt-4">
            <SidebarGroupLabel className="px-5 text-[10px] font-black uppercase tracking-[0.2em] text-sidebar-foreground/30 mb-2">
              Data & Pendukung
            </SidebarGroupLabel>
            <SidebarGroupContent className="px-2">
              {renderMenuItems(supportItems)}
            </SidebarGroupContent>
          </SidebarGroup>
        </SidebarContent>
      <SidebarFooter className="p-4 border-t border-border/50 bg-background/50">
        <SidebarMenu>
          <SidebarMenuItem>
            <SidebarMenuButton 
              onClick={() => {
                const { signOut } = require("next-auth/react");
                signOut({ callbackUrl: "/auth/login" });
              }}
              className="hover:bg-destructive/10 hover:text-destructive px-5 py-5 transition-all h-auto w-full group/logout"
            >
              <div className="flex items-center gap-3 w-full">
                <div className="h-9 w-9 rounded-lg bg-muted flex items-center justify-center shrink-0 group-hover/logout:bg-destructive/20 transition-colors">
                  <LogOut className="h-5 w-5 text-muted-foreground group-hover/logout:text-destructive transition-colors" />
                </div>
                <span className="font-bold text-sm text-foreground group-hover/logout:text-destructive transition-colors">Keluar Aplikasi</span>
              </div>
            </SidebarMenuButton>
          </SidebarMenuItem>
        </SidebarMenu>
      </SidebarFooter>
    </Sidebar>
  );
}
