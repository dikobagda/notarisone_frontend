@import "tailwindcss";

@plugin "../../node_modules/tailwindcss-animate";

@custom-variant dark (&:is(.dark *));

@theme {
  --font-sans: var(--font-montserrat), ui-sans-serif, system-ui, sans-serif;
  --font-mono: var(--font-geist-mono);

  /* Mapping shadcn variables to Tailwind v4 utilities */
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);

  --radius-lg: var(--radius);
  --radius-md: calc(var(--radius) - 2px);
  --radius-sm: calc(var(--radius) - 4px);

  --color-sidebar-background: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);

  @keyframes accordion-down {
    from { height: 0; }
    to { height: var(--radix-accordion-content-height); }
  }
  @keyframes accordion-up {
    from { height: var(--radix-accordion-content-height); }
    to { height: 0; }
  }
  @keyframes scan {
    0% { top: 0; }
    50% { top: 100%; }
    100% { top: 0; }
  }
}

:root {
  --background: oklch(0.98 0.005 240);
  --foreground: oklch(0.15 0.02 240);
  --card: oklch(1 0 0);
  --card-foreground: oklch(0.15 0.02 240);
  --popover: oklch(1 0 0);
  --popover-foreground: oklch(0.15 0.02 240);
  --primary: oklch(0.25 0.04 240);
  --primary-foreground: oklch(0.98 0.005 240);
  --secondary: oklch(0.9 0.01 240);
  --secondary-foreground: oklch(0.2 0.02 240);
  --muted: oklch(0.9 0.01 240);
  --muted-foreground: oklch(0.45 0.02 240);
  --accent: oklch(0.85 0.05 85);
  --accent-foreground: oklch(0.2 0.02 40);
  --destructive: oklch(0.6 0.15 25);
  --destructive-foreground: oklch(0.98 0.005 240);
  --border: oklch(0.9 0.01 240);
  --input: oklch(0.9 0.01 240);
  --ring: oklch(0.25 0.04 240);
  --chart-1: oklch(0.65 0.15 210);
  --chart-2: oklch(0.6 0.15 175);
  --chart-3: oklch(0.6 0.15 45);
  --chart-4: oklch(0.7 0.15 85);
  --chart-5: oklch(0.7 0.15 15);
  --radius: 0.625rem;
  --sidebar: oklch(1 0 0); /* Pure White */
  --sidebar-foreground: oklch(0 0 0); /* Solid Black for inactive text */
  --sidebar-primary: oklch(0.6 0.2 250); /* Royal Blue for active/hover */
  --sidebar-primary-foreground: oklch(1 0 0);
  --sidebar-accent: oklch(0.95 0.01 240); /* Light Gray for hover */
  --sidebar-accent-foreground: oklch(0 0 0);
  --sidebar-border: oklch(0.9 0.01 240);
  --sidebar-ring: oklch(0.6 0.2 250);
}

.dark {
  --background: oklch(0.15 0.02 240);
  --foreground: oklch(0.98 0.005 240);
  --card: oklch(0.18 0.02 240);
  --card-foreground: oklch(0.98 0.005 240);
  --popover: oklch(0.18 0.02 240);
  --popover-foreground: oklch(0.98 0.005 240);
  --primary: oklch(0.98 0.005 240);
  --primary-foreground: oklch(0.15 0.02 240);
  --secondary: oklch(0.25 0.02 240);
  --secondary-foreground: oklch(0.98 0.005 240);
  --muted: oklch(0.25 0.02 240);
  --muted-foreground: oklch(0.7 0.01 240);
  --accent: oklch(0.7 0.1 85);
  --accent-foreground: oklch(0.98 0.005 240);
  --destructive: oklch(0.4 0.15 25);
  --destructive-foreground: oklch(0.98 0.005 240);
  --border: oklch(0.25 0.02 240);
  --input: oklch(0.25 0.02 240);
  --ring: oklch(0.9 0.01 240);
  --chart-1: oklch(0.5 0.15 210);
  --chart-2: oklch(0.7 0.15 175);
  --chart-3: oklch(0.75 0.15 45);
  --chart-4: oklch(0.6 0.15 150);
  --chart-5: oklch(0.85 0.15 85);
  --sidebar: oklch(0.15 0.02 240);
  --sidebar-foreground: oklch(0.95 0.005 240);
  --sidebar-primary: oklch(0.85 0.05 85);
  --sidebar-primary-foreground: oklch(0.15 0.02 240);
  --sidebar-accent: oklch(0.25 0.02 240);
  --sidebar-accent-foreground: oklch(0.95 0.005 240);
  --sidebar-border: oklch(0.25 0.02 240);
  --sidebar-ring: oklch(0.85 0.05 85);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background: oklch(0.9 0.01 240);
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: oklch(0.85 0.02 240);
  }

  .dark ::-webkit-scrollbar-thumb {
    background: oklch(0.3 0.02 240);
  }

  .dark ::-webkit-scrollbar-thumb:hover {
    background: oklch(0.35 0.02 240);
  }

  * {
    scrollbar-width: thin;
    scrollbar-color: oklch(0.9 0.01 240) transparent;
  }
}