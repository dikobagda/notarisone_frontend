                  </TableRow>
                ))}
              </TableBody>
            </Table>
            <Button variant="link" className="w-full mt-4 text-muted-foreground">Lihat Semua Akta</Button>
          </CardContent>
        </Card>

        {/* Task List / Reminders */}
        <Card className="lg:col-span-3 border-none shadow-sm">
          <CardHeader>
            <CardTitle>Tugas & Pengingat</CardTitle>
            <CardDescription>Aktivitas yang perlu perhatian segera.</CardDescription>
          </CardHeader>
          <CardContent>
            <div className="space-y-6">
              {[
                { time: "09:00", task: "Tanda tangan AJB Budi Santoso", type: "Urgent" },
                { time: "11:30", task: "Review draf PT Maju Jaya", type: "Normal" },
                { time: "14:00", task: "Konsultasi Wasiat Robert Chen", type: "Normal" },
                { time: "Besok", task: "Kirim laporan bulanan ke INI", type: "Urgent" },
              ].map((item, i) => (
                <div key={i} className="flex items-start gap-4">
                  <div className="min-w-[50px] text-sm font-semibold text-accent">{item.time}</div>
                  <div className="flex-1 space-y-1">
                    <p className="text-sm font-medium leading-none">{item.task}</p>
                    <p className="text-xs text-muted-foreground">{item.type} • Kantor Notaris</p>
                  </div>
                  {item.type === "Urgent" && (
                     <div className="h-2 w-2 rounded-full bg-destructive animate-pulse" />
                  )}
                </div>
              ))}
            </div>
            <Button className="w-full mt-8 variant-outline" variant="outline">Lihat Kalender</Button>
          </CardContent>
        </Card>
