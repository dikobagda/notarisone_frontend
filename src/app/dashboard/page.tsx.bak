  Plus
} from "lucide-react";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { 
  Table, 
  TableBody, 
  TableCell, 
  TableHead, 
  TableHeader, 
  TableRow 
} from "@/components/ui/table";

const stats = [
  {
    title: "Total Akta",
    value: "1,284",
    description: "+12.5% dari bulan lalu",
    icon: FileText,
    trend: "up",
  },
  {
    title: "Klien Baru",
    value: "48",
    description: "Bulan ini",
    icon: Users,
    trend: "up",
  },
  {
    title: "Pemasukan",
    value: "Rp 128.5M",
    description: "Estimasi pendapatan",
    icon: TrendingUp,
    trend: "up",
  },
  {
    title: "Janji Temu",
    value: "12",
    description: "Minggu ini",
    icon: Calendar,
    trend: "none",
  },
];

const recentDeeds = [
  { id: "1", title: "Pendirian PT Maju Jaya", client: "Budi Santoso", date: "14 Apr 2024", status: "Draft" },
